# 환경 변수 예시 파일 (.env 로 복사해서 사용)

# Postgres 연결 문자열 (필수 — 없으면 모든 API가 503 DB_NOT_CONFIGURED 반환)
# Neon(https://neon.tech) 무료 티어 권장. Vercel Storage 탭에서 Neon 연결 시 자동 주입됨.
# 예: postgresql://user:password@ep-xxx.ap-southeast-1.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=

# JWT 서명에 사용하는 비밀 키 (데모용 기본값)
JWT_SECRET=demo-secret-key

# API 기본 주소 - 로컬은 vite proxy 사용, Vercel 배포 시에만 설정
VITE_API_BASE_URL=
