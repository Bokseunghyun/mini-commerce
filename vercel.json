{
  "version": 2,
  "builds": [
    { "src": "package.json", "use": "@vercel/static-build", "config": { "distDir": "dist" } },
    { "src": "api/**/*.js", "use": "@vercel/node" }
  ],
  "routes": [
    { "handle": "filesystem" },

    { "src": "/api/products/([^/]+)", "dest": "/api/products/[id].js?id=$1" },

    { "src": "/api/orders/([^/]+)", "dest": "/api/orders/[id].js?id=$1" },

    { "src": "/api/(.*)", "dest": "/api/$1.js" },

    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
